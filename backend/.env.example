DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave DB_ENGINE unset (or "sqlite") to use SQLite for local dev.
# Set DB_ENGINE=postgres and fill these in to use PostgreSQL instead.
DB_ENGINE=sqlite
DB_NAME=rentora
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Channels + cache backend — defaults to in-memory (fine for a single dev
# process). Set CHANNELS_BACKEND=redis to use Redis for both the WebSocket
# channel layer and the Django cache (needed for chat online-presence
# tracking to work correctly across multiple processes/workers).
CHANNELS_BACKEND=
REDIS_URL=redis://localhost:6379/0
